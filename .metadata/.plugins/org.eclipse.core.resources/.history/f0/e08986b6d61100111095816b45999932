<%@ page contentType="text/html;charset=UTF-8" language="java" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%@ taglib prefix="fn" uri="jakarta.tags.functions" %>

<%
  // Calcul nombre d'articles panier pour le badge
  int nbPanier = 0;
  models.Client clientNav = (models.Client) session.getAttribute("client");
  if (clientNav != null) {
    java.util.List<?> panierNav = (java.util.List<?>) request.getAttribute("panierItems");
    if (panierNav != null) nbPanier = panierNav.size();
  }
  String activePage = (String) request.getAttribute("activePage");
%>

<nav class="fixed top-0 left-0 right-0 z-50 bg-gray-900/80 backdrop-blur-xl border-b border-gray-800" 
     role="navigation" 
     aria-label="Navigation principale">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- Logo -->
      <a href="${pageContext.request.contextPath}/catalogue" 
         class="flex items-center gap-2 group" 
         aria-label="TechShop Accueil">
        <div class="text-2xl transform group-hover:scale-110 group-hover:rotate-12 transition-all duration-300" 
             aria-hidden="true">⚡</div>
        <span class="text-xl md:text-2xl font-display font-bold">
          <span class="text-white">Tech</span>
          <span class="bg-gradient-to-r from-gold to-gold-dark bg-clip-text text-transparent">Shop</span>
        </span>
      </a>

      <!-- Navigation principale (Desktop) -->
      <ul class="hidden md:flex items-center gap-1" role="list">
        <li>
          <a href="${pageContext.request.contextPath}/catalogue"
             class="px-4 py-2 rounded-xl text-sm font-medium transition-all duration-300 
                    ${activePage == 'catalogue' 
                      ? 'bg-gold/10 text-gold border border-gold/20' 
                      : 'text-gray-300 hover:text-white hover:bg-gray-800/50'}">
            <span class="mr-2" aria-hidden="true">🏪</span> Catalogue
          </a>
        </li>
        <c:if test="${not empty sessionScope.client}">
          <li>
            <a href="${pageContext.request.contextPath}/commande/historique"
               class="px-4 py-2 rounded-xl text-sm font-medium transition-all duration-300 
                      ${activePage == 'commandes' 
                        ? 'bg-gold/10 text-gold border border-gold/20' 
                        : 'text-gray-300 hover:text-white hover:bg-gray-800/50'}">
              <span class="mr-2" aria-hidden="true">📦</span> Commandes
            </a>
          </li>
        </c:if>
        <c:if test="${sessionScope.client.admin}">
          <li>
            <a href="${pageContext.request.contextPath}/admin"
               class="px-4 py-2 rounded-xl text-sm font-medium transition-all duration-300 
                      ${activePage == 'admin' 
                        ? 'bg-gold/10 text-gold border border-gold/20' 
                        : 'text-gray-300 hover:text-white hover:bg-gray-800/50'}">
              <span class="mr-2" aria-hidden="true">⚙️</span> Administration
            </a>
          </li>
        </c:if>
      </ul>

      <!-- Actions droite -->
      <div class="flex items-center gap-3">

        <!-- Panier (clients seulement) -->
        <c:if test="${not empty sessionScope.client and not sessionScope.client.admin}">
          <a href="${pageContext.request.contextPath}/panier"
             class="relative flex items-center gap-2 px-4 py-2 bg-gray-800/50 hover:bg-gray-800 rounded-xl transition-all duration-300 group"
             aria-label="Panier (${nbPanier} articles)">
            <span class="text-xl transform group-hover:scale-110 transition-transform duration-300" 
                  aria-hidden="true">🛒</span>
            <span class="text-sm font-medium text-gray-300 group-hover:text-white">Panier</span>
            <c:if test="${nbPanier > 0}">
              <span class="absolute -top-2 -right-2 w-6 h-6 flex items-center justify-center 
                         bg-gradient-to-r from-gold to-gold-dark text-gray-900 text-xs font-bold rounded-full 
                         animate-pulse-slow" 
                    aria-hidden="true">${nbPanier}</span>
            </c:if>
          </a>
        </c:if>

        <!-- Utilisateur connecté -->
        <c:choose>
          <c:when test="${not empty sessionScope.client}">
            <div class="relative group/menu" x-data="{ open: false }" @click.away="open = false">
              <button class="flex items-center gap-3 px-3 py-2 bg-gray-800/50 hover:bg-gray-800 rounded-xl transition-all duration-300"
                      @click="open = !open"
                      aria-haspopup="true"
                      :aria-expanded="open"
                      type="button">
                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-gold to-gold-dark 
                            flex items-center justify-center text-gray-900 font-bold text-sm">
                  ${fn:substring(sessionScope.client.prenom, 0, 1)}${fn:substring(sessionScope.client.nom, 0, 1)}
                </div>
                <span class="text-sm font-medium text-gray-300 hidden sm:block">
                  ${sessionScope.client.prenom}
                </span>
                <c:if test="${sessionScope.client.admin}">
                  <span class="px-2 py-0.5 bg-gold/20 text-gold text-xs font-bold rounded-full border border-gold/30">
                    ADMIN
                  </span>
                </c:if>
                <span class="text-xs text-gray-500 transition-transform duration-300" 
                      :class="{ 'rotate-180': open }" 
                      aria-hidden="true">▼</span>
              </button>

              <!-- Dropdown menu -->
              <div class="absolute right-0 mt-2 w-64 bg-gray-800 border border-gray-700 rounded-2xl shadow-2xl 
                          opacity-0 invisible group-hover/menu:opacity-100 group-hover/menu:visible 
                          transition-all duration-300 transform origin-top-right"
                   x-show="open"
                   x-transition:enter="transition ease-out duration-200"
                   x-transition:enter-start="opacity-0 scale-95"
                   x-transition:enter-end="opacity-100 scale-100"
                   x-transition:leave="transition ease-in duration-150"
                   x-transition:leave-start="opacity-100 scale-100"
                   x-transition:leave-end="opacity-0 scale-95"
                   role="menu">
                
                <!-- User info -->
                <div class="p-4 border-b border-gray-700">
                  <div class="font-display font-semibold text-white">${sessionScope.client.nomComplet}</div>
                  <div class="text-xs text-gray-400 mt-1">${sessionScope.client.email}</div>
                </div>

                <!-- Menu items -->
                <div class="p-2">
                  <c:if test="${not sessionScope.client.admin}">
                    <a href="${pageContext.request.contextPath}/commande/historique"
                       class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-300 hover:text-white 
                              hover:bg-gray-700/50 rounded-xl transition-all duration-200"
                       role="menuitem">
                      <span class="text-xl" aria-hidden="true">📦</span>
                      <span>Mes commandes</span>
                    </a>
                  </c:if>
                  <c:if test="${sessionScope.client.admin}">
                    <a href="${pageContext.request.contextPath}/admin"
                       class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-300 hover:text-white 
                              hover:bg-gray-700/50 rounded-xl transition-all duration-200"
                       role="menuitem">
                      <span class="text-xl" aria-hidden="true">⚙️</span>
                      <span>Dashboard admin</span>
                    </a>
                  </c:if>
                </div>

                <!-- Divider -->
                <div class="h-px bg-gray-700 my-1"></div>

                <!-- Logout -->
                <div class="p-2">
                  <a href="${pageContext.request.contextPath}/logout"
                     class="flex items-center gap-3 px-4 py-2.5 text-sm text-rose-400 hover:text-rose-300 
                            hover:bg-rose-500/10 rounded-xl transition-all duration-200"
                     role="menuitem">
                    <span class="text-xl" aria-hidden="true">🚪</span>
                    <span>Se déconnecter</span>
                  </a>
                </div>
              </div>
            </div>
          </c:when>

          <!-- Non connecté -->
          <c:otherwise>
            <a href="${pageContext.request.contextPath}/login"
               class="px-4 py-2 text-sm font-medium text-gray-300 hover:text-white 
                      hover:bg-gray-800 rounded-xl transition-all duration-300">
              Connexion
            </a>
            <a href="${pageContext.request.contextPath}/inscription"
               class="px-4 py-2 bg-gradient-to-r from-gold to-gold-dark text-gray-900 
                      text-sm font-medium rounded-xl hover:shadow-lg hover:shadow-gold/20 
                      transition-all duration-300 transform hover:scale-105">
              S'inscrire
            </a>
          </c:otherwise>
        </c:choose>

        <!-- Mobile menu button -->
        <button class="md:hidden relative w-10 h-10 flex flex-col items-center justify-center gap-1.5 
                       bg-gray-800/50 hover:bg-gray-800 rounded-xl transition-all duration-300"
                @click="mobileOpen = !mobileOpen"
                aria-label="Menu"
                aria-expanded="false">
          <span class="w-5 h-0.5 bg-gray-300 rounded-full transition-all duration-300"
                :class="{ 'rotate-45 translate-y-2' : mobileOpen }"></span>
          <span class="w-5 h-0.5 bg-gray-300 rounded-full transition-all duration-300"
                :class="{ 'opacity-0' : mobileOpen }"></span>
          <span class="w-5 h-0.5 bg-gray-300 rounded-full transition-all duration-300"
                :class="{ '-rotate-45 -translate-y-2' : mobileOpen }"></span>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div class="md:hidden border-t border-gray-800 mt-2 py-4 space-y-1"
         x-show="mobileOpen"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 -translate-y-4"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100 translate-y-0"
         x-transition:leave-end="opacity-0 -translate-y-4"
         style="display: none;">
      
      <a href="${pageContext.request.contextPath}/catalogue"
         class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 
                ${activePage == 'catalogue' ? 'bg-gold/10 text-gold' : 'text-gray-300 hover:bg-gray-800'}">
        <span class="text-xl" aria-hidden="true">🏪</span>
        <span class="font-medium">Catalogue</span>
      </a>
      
      <c:if test="${not empty sessionScope.client}">
        <a href="${pageContext.request.contextPath}/commande/historique"
           class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 
                  ${activePage == 'commandes' ? 'bg-gold/10 text-gold' : 'text-gray-300 hover:bg-gray-800'}">
          <span class="text-xl" aria-hidden="true">📦</span>
          <span class="font-medium">Commandes</span>
        </a>
      </c:if>
      
      <c:if test="${sessionScope.client.admin}">
        <a href="${pageContext.request.contextPath}/admin"
           class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 
                  ${activePage == 'admin' ? 'bg-gold/10 text-gold' : 'text-gray-300 hover:bg-gray-800'}">
          <span class="text-xl" aria-hidden="true">⚙️</span>
          <span class="font-medium">Administration</span>
        </a>
      </c:if>
    </div>
  </div>
</nav>

<!-- Script pour Alpine.js (nécessaire pour les interactions) -->
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

<!-- Script pour gérer l'état mobile -->
<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('navbar', () => ({
      mobileOpen: false,
      init() {
        // Fermer le menu mobile quand on redimensionne au-dessus de md
        window.addEventListener('resize', () => {
          if (window.innerWidth >= 768) {
            this.mobileOpen = false;
          }
        });
      }
    }));
  });
</script>

<!-- Espacement pour compenser la navbar fixe -->
<div class="h-16 md:h-20"></div>