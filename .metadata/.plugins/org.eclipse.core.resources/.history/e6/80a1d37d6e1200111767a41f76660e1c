<%@ page contentType="text/html;charset=UTF-8" language="java" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%@ taglib prefix="fmt" uri="jakarta.tags.fmt" %>
<%@ taglib prefix="fn" uri="jakarta.tags.functions" %>
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gestion des Commandes — Admin TechShop</title>
  <!-- TailwindCSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Configuration Tailwind personnalisée -->
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            gold: '#D4AF37',
            'gold-dark': '#B8860B',
            'text-muted': '#9ca3af',
            'border': '#374151',
          },
          fontFamily: {
            display: ['Syne', 'sans-serif'],
            sans: ['DM Sans', 'sans-serif'],
            mono: ['DM Mono', 'monospace'],
          },
          animation: {
            'fade-up': 'fadeUp 0.6s ease-out forwards',
          },
          keyframes: {
            fadeUp: {
              '0%': { opacity: '0', transform: 'translateY(20px)' },
              '100%': { opacity: '1', transform: 'translateY(0)' },
            }
          }
        }
      }
    }
  </script>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400&display=swap" rel="stylesheet">
</head>
<body class="bg-gradient-to-br from-gray-950 via-gray-900 to-gray-950 text-gray-100 min-h-screen font-sans antialiased">
<%@ include file="../../common/navbar.jsp" %>

<div class="flex min-h-screen">
  <!-- Sidebar -->
  <nav class="w-64 shrink-0 bg-gray-900/80 backdrop-blur-xl border-r border-gray-800 p-4 flex flex-col" aria-label="Navigation administration">
    <div class="pb-3 mb-4 border-b border-gray-800">
      <div class="text-xs font-bold tracking-wider uppercase text-gold flex items-center gap-2">⚙️ Administration</div>
    </div>
    <div class="space-y-1">
      <a href="${pageContext.request.contextPath}/admin" class="flex items-center gap-3 px-3 py-2 text-gray-400 hover:text-white hover:bg-gray-800/50 rounded-xl transition-all duration-200"><span class="text-lg">📊</span> Dashboard</a>
      <a href="${pageContext.request.contextPath}/admin/produits" class="flex items-center gap-3 px-3 py-2 text-gray-400 hover:text-white hover:bg-gray-800/50 rounded-xl transition-all duration-200"><span class="text-lg">📱</span> Produits</a>
      <a href="${pageContext.request.contextPath}/admin/categories" class="flex items-center gap-3 px-3 py-2 text-gray-400 hover:text-white hover:bg-gray-800/50 rounded-xl transition-all duration-200"><span class="text-lg">🏷️</span> Catégories</a>
      <a href="${pageContext.request.contextPath}/admin/commandes" class="flex items-center gap-3 px-3 py-2 bg-gold/10 text-gold rounded-xl border border-gold/20"><span class="text-lg">📦</span> Commandes</a>
    </div>
  </nav>

  <!-- Contenu principal -->
  <main class="flex-1 p-8 overflow-y-auto">
    <!-- Alertes -->
    <c:if test="${not empty sessionScope.succes}">
      <div class="mb-6 p-4 bg-emerald-900/50 border border-emerald-600 rounded-xl flex items-center gap-3 text-emerald-200 animate-fade-up" role="alert">
        <span class="text-2xl" aria-hidden="true">✅</span><span>${sessionScope.succes}</span>
      </div>
      <c:remove var="succes" scope="session"/>
    </c:if>
    <c:if test="${not empty sessionScope.erreur}">
      <div class="mb-6 p-4 bg-rose-900/50 border border-rose-600 rounded-xl flex items-center gap-3 text-rose-200 animate-fade-up" role="alert">
        <span class="text-2xl" aria-hidden="true">⚠️</span><span>${sessionScope.erreur}</span>
      </div>
      <c:remove var="erreur" scope="session"/>
    </c:if>

    <!-- En-tête -->
    <div class="mb-8 animate-fade-up">
      <div class="flex items-center gap-2 text-sm text-gray-500 mb-2">
        <a href="${pageContext.request.contextPath}/admin" class="hover:text-gold transition-colors">Admin</a> <span class="text-gray-600">›</span> <span class="text-gray-400">Commandes</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-display font-bold tracking-tight">Gestion des <span class="text-gold">commandes</span></h1>
    </div>

    <!-- Filtres statut -->
    <div class="flex flex-wrap gap-2 mb-6 animate-fade-up" style="animation-delay: 0.1s">
      <a href="${pageContext.request.contextPath}/admin/commandes"
         class="px-4 py-2 text-sm font-medium rounded-xl transition-all duration-300
                ${empty statutFiltre 
                  ? 'bg-gold text-gray-900' 
                  : 'bg-gray-800/50 text-gray-400 hover:text-white hover:bg-gray-700 border border-gray-700'}">
        Toutes
      </a>
      <a href="${pageContext.request.contextPath}/admin/commandes?statut=EN_COURS"
         class="px-4 py-2 text-sm font-medium rounded-xl transition-all duration-300 flex items-center gap-1
                ${statutFiltre == 'EN_COURS' 
                  ? 'bg-gold text-gray-900' 
                  : 'bg-gray-800/50 text-gray-400 hover:text-white hover:bg-gray-700 border border-gray-700'}">
        🔄 En cours
      </a>
      <a href="${pageContext.request.contextPath}/admin/commandes?statut=VALIDEE"
         class="px-4 py-2 text-sm font-medium rounded-xl transition-all duration-300 flex items-center gap-1
                ${statutFiltre == 'VALIDEE' 
                  ? 'bg-gold text-gray-900' 
                  : 'bg-gray-800/50 text-gray-400 hover:text-white hover:bg-gray-700 border border-gray-700'}">
        ✅ Validées
      </a>
      <a href="${pageContext.request.contextPath}/admin/commandes?statut=ANNULEE"
         class="px-4 py-2 text-sm font-medium rounded-xl transition-all duration-300 flex items-center gap-1
                ${statutFiltre == 'ANNULEE' 
                  ? 'bg-gold text-gray-900' 
                  : 'bg-gray-800/50 text-gray-400 hover:text-white hover:bg-gray-700 border border-gray-700'}">
        ✗ Annulées
      </a>
    </div>

    <!-- Tableau -->
    <div class="bg-gray-800/30 backdrop-blur-sm border border-gray-700 rounded-2xl overflow-hidden animate-fade-up" style="animation-delay: 0.2s">
      <div class="overflow-x-auto">
        <table class="w-full" aria-label="Liste des commandes">
          <thead>
            <tr class="border-b border-gray-700 bg-gray-900/50">
              <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">N° Commande</th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Client</th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Date</th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Articles</th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Total</th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Statut</th>
              <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <c:forEach var="cmd" items="${commandes}">
              <tr class="hover:bg-gray-800/50 transition-colors">
                <td class="px-6 py-4">
                  <span class="font-mono text-gray-500">#${cmd.id}</span>
                </td>
                <td class="px-6 py-4">
                  <div class="font-medium text-white">${cmd.client.nomComplet}</div>
                  <div class="text-xs text-gray-500">${cmd.client.email}</div>
                </td>
                <td class="px-6 py-4">
                  <div class="text-sm">
                    <fmt:formatDate value="${cmd.cateCommandeAsDate}" pattern="dd/MM/yyyy"/>
                  </div>
                  <div class="text-xs text-gray-500">
                    <fmt:formatDate value="${cmd.cateCommandeAsDate}" pattern="HH:mm"/>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <span class="text-white font-semibold">${fn:length(cmd.lignes)}</span>
                  <span class="text-gray-500 text-sm"> article${fn:length(cmd.lignes) > 1 ? 's' : ''}</span>
                </td>
                <td class="px-6 py-4">
                  <span class="font-mono text-gold font-bold">
                    <fmt:formatNumber value="${cmd.total}" pattern="#,##0.00"/> €
                  </span>
                </td>
                <td class="px-6 py-4">
                  <c:choose>
                    <c:when test="${cmd.statutName eq 'EN_COURS'}">
                      <span class="px-2 py-1 bg-gold/10 text-gold text-xs font-bold rounded-full border border-gold/20 flex items-center gap-1 w-fit">🔄 En cours</span>
                    </c:when>
                    <c:when test="${cmd.statutName eq 'VALIDEE'}">
                      <span class="px-2 py-1 bg-emerald-500/10 text-emerald-500 text-xs font-bold rounded-full border border-emerald-500/20 flex items-center gap-1 w-fit">✅ Validée</span>
                    </c:when>
                    <c:when test="${cmd.statutName eq 'ANNULEE'}">
                      <span class="px-2 py-1 bg-rose-500/10 text-rose-500 text-xs font-bold rounded-full border border-rose-500/20 flex items-center gap-1 w-fit">✗ Annulée</span>
                    </c:when>
                  </c:choose>
                </td>
                <td class="px-6 py-4">
                  <!-- Changement statut — RM-03 : VALIDEE est définitive -->
                  <c:if test="${cmd.statutName eq 'EN_COURS'}">
                    <div class="flex flex-wrap gap-2">
                      <form action="${pageContext.request.contextPath}/admin/commandes/statut" method="post"
                            onsubmit="return confirm('Valider définitivement cette commande ? Cette action est IRRÉVERSIBLE.')">
                        <input type="hidden" name="commandeId" value="${cmd.id}">
                        <input type="hidden" name="statut" value="VALIDEE">
                        <button type="submit" class="px-3 h-8 bg-emerald-500/20 hover:bg-emerald-500/30 text-emerald-500 text-xs font-medium rounded-lg transition-colors flex items-center gap-1"
                                aria-label="Valider la commande #${cmd.id}">✅ Valider</button>
                      </form>
                      <form action="${pageContext.request.contextPath}/admin/commandes/statut" method="post"
                            onsubmit="return confirm('Annuler cette commande ?')">
                        <input type="hidden" name="commandeId" value="${cmd.id}">
                        <input type="hidden" name="statut" value="ANNULEE">
                        <button type="submit" class="px-3 h-8 bg-rose-500/20 hover:bg-rose-500/30 text-rose-500 text-xs font-medium rounded-lg transition-colors flex items-center gap-1"
                                aria-label="Annuler la commande #${cmd.id}">✗ Annuler</button>
                      </form>
                    </div>
                  </c:if>
                  <c:if test="${cmd.statutName ne 'EN_COURS'}">
                    <!-- RM-03 : commande définitive, aucune action possible -->
                    <span class="text-xs text-gray-500 italic">Définitive (RM-03)</span>
                  </c:if>
                </td>
              </tr>
            </c:forEach>
            <c:if test="${empty commandes}">
              <tr>
                <td colspan="7" class="px-6 py-12 text-center text-gray-500">Aucune commande trouvée</td>
              </tr>
            </c:if>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<!-- Footer -->
<footer class="border-t border-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <p class="text-center text-gray-500 text-sm">© 2025 TechShop — Administration</p>
  </div>
</footer>

</body>
</html>