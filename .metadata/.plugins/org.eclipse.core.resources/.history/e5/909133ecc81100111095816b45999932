<%@ page contentType="text/html;charset=UTF-8" language="java" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%@ taglib prefix="fmt" uri="jakarta.tags.fmt" %>
<c:set var="activePage" value="commandes" scope="request"/>
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mes Commandes — TechShop</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/style.css">
</head>
<body>
<%@ include file="../common/navbar.jsp" %>

<div class="page-wrapper">
  <div class="page-header fade-up">
    <h1 class="page-title">Mes <span style="color:var(--gold)">commandes</span></h1>
    <p class="page-subtitle">Historique et suivi de vos commandes</p>
  </div>

  <c:choose>
    <c:when test="${empty commandes}">
      <div style="text-align:center;padding:5rem 2rem;" class="fade-up">
        <div style="font-size:5rem;margin-bottom:1.5rem;" aria-hidden="true">📦</div>
        <h2 style="font-family:var(--font-display);font-size:1.5rem;margin-bottom:0.75rem;">Aucune commande pour le moment</h2>
        <p style="color:var(--text-secondary);margin-bottom:2rem;">Commencez par explorer notre catalogue</p>
        <a href="${pageContext.request.contextPath}/catalogue" class="btn btn-primary btn-lg">
          🏪 Découvrir le catalogue
        </a>
      </div>
    </c:when>
    <c:otherwise>
      <div class="fade-up fade-up-1">
        <c:forEach var="commande" items="${commandes}" varStatus="loop">
          <div class="card" style="margin-bottom:1rem;animation:fadeUp 0.4s ease ${loop.index * 0.08}s both;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:1rem;margin-bottom:1rem;">
              <div>
                <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.4rem;">
                  <span style="font-family:var(--font-mono);font-size:0.85rem;color:var(--text-muted);">
                    #${commande.id}
                  </span>
                  <c:choose>
                    <c:when test="${commande.statut == 'EN_COURS'}">
                      <span class="badge badge-en-cours">🔄 En cours</span>
                    </c:when>
                    <c:when test="${commande.statut == 'VALIDEE'}">
                      <span class="badge badge-validee">✅ Validée</span>
                    </c:when>
                    <c:when test="${commande.statut == 'ANNULEE'}">
                      <span class="badge badge-annulee">✗ Annulée</span>
                    </c:when>
                  </c:choose>
                </div>
                <div style="font-size:0.82rem;color:var(--text-muted);">
                  <fmt:formatDate value="${commande.dateCommande}" pattern="dd/MM/yyyy à HH:mm"/>
                </div>
              </div>
              <div style="text-align:right;">
                <div style="font-family:var(--font-display);font-size:1.4rem;font-weight:700;color:var(--gold);">
                  <fmt:formatNumber value="${commande.total}" pattern="#,##0.00"/> €
                </div>
                <div style="font-size:0.78rem;color:var(--text-muted);">
                  ${fn:length(commande.lignes)} article${fn:length(commande.lignes) > 1 ? 's' : ''}
                </div>
              </div>
            </div>

            <%-- Lignes de commande --%>
            <div style="border-top:1px solid var(--border);padding-top:1rem;">
              <c:forEach var="ligne" items="${commande.lignes}">
                <div style="display:flex;justify-content:space-between;align-items:center;padding:0.4rem 0;font-size:0.85rem;">
                  <div style="display:flex;align-items:center;gap:0.75rem;">
                    <span style="color:var(--text-muted);font-family:var(--font-mono);
                                 background:var(--bg-elevated);padding:0.15rem 0.5rem;
                                 border-radius:4px;">×${ligne.quantite}</span>
                    <span style="color:var(--text-primary);">${ligne.produit.nom}</span>
                  </div>
                  <span style="color:var(--text-secondary);">
                    <fmt:formatNumber value="${ligne.sousTotal}" pattern="#,##0.00"/> €
                  </span>
                </div>
              </c:forEach>
            </div>

            <div style="margin-top:1rem;padding-top:0.75rem;border-top:1px solid var(--border);
                        font-size:0.78rem;color:var(--text-muted);">
              📍 Livraison : ${commande.adresseLivraison}
            </div>
          </div>
        </c:forEach>
      </div>
    </c:otherwise>
  </c:choose>
</div>

<footer class="site-footer"><p>© 2025 TechShop</p></footer>
</body>
</html>
