<%@ page contentType="text/html;charset=UTF-8" language="java" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%@ taglib prefix="fn" uri="jakarta.tags.functions" %>
<c:set var="activePage" value="catalogue" scope="request"/>
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Catalogue — TechShop</title>
    <!-- TailwindCSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Configuration Tailwind personnalisée -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        gold: '#D4AF37',
                        'gold-light': '#F5E7C8',
                        'gold-dark': '#B8860B',
                        'dark-bg': '#111827',
                        'card-bg': '#1F2937',
                        'card-border': '#374151',
                        'text-primary': '#F9FAFB',
                        'text-secondary': '#D1D5DB',
                        'text-muted': '#9CA3AF',
                    },
                    fontFamily: {
                        display: ['Syne', 'sans-serif'],
                        sans: ['DM Sans', 'sans-serif'],
                        mono: ['DM Mono', 'monospace'],
                    },
                    animation: {
                        'fade-up': 'fadeUp 0.6s ease-out forwards',
                        'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                    },
                    keyframes: {
                        fadeUp: {
                            '0%': { opacity: '0', transform: 'translateY(20px)' },
                            '100%': { opacity: '1', transform: 'translateY(0)' },
                        }
                    }
                }
            }
        }
    </script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400&display=swap" rel="stylesheet">
</head>
<body class="bg-gradient-to-br from-gray-950 via-gray-900 to-gray-950 text-gray-100 min-h-screen font-sans antialiased">

<%@ include file="navbar.jsp" %>

<!-- Main Content -->
<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">

    <!-- Alertes session -->
    <c:if test="${not empty sessionScope.succes}">
        <div class="mb-6 p-4 bg-emerald-900/50 border border-emerald-600 rounded-xl backdrop-blur-sm animate-pulse-slow flex items-center gap-3 text-emerald-200" role="alert">
            <span class="text-2xl">✅</span>
            <span class="font-medium">${sessionScope.succes}</span>
            <c:remove var="succes" scope="session"/>
        </div>
    </c:if>
    <c:if test="${not empty sessionScope.erreur}">
        <div class="mb-6 p-4 bg-rose-900/50 border border-rose-600 rounded-xl backdrop-blur-sm flex items-center gap-3 text-rose-200" role="alert">
            <span class="text-2xl">⚠️</span>
            <span class="font-medium">${sessionScope.erreur}</span>
            <c:remove var="erreur" scope="session"/>
        </div>
    </c:if>

    <!-- En-tête -->
    <div class="mb-8 md:mb-12 animate-fade-up">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold tracking-tight mb-3">
            Catalogue 
            <span class="bg-gradient-to-r from-gold to-gold-dark bg-clip-text text-transparent">électronique</span>
        </h1>
        
    </div>

    <!-- Barre de recherche -->
    <div class="mb-8 animate-fade-up" style="animation-delay: 0.1s">
        <form action="${pageContext.request.contextPath}/catalogue" method="get" role="search">
            <div class="relative flex items-center">
                <span class="absolute left-4 text-gray-400 text-xl" aria-hidden="true">🔍</span>
                <input type="search"
                       name="q"
                       value="<c:out value='${keyword}'/>"
                       placeholder="Rechercher un produit, une marque..."
                       aria-label="Rechercher un produit"
                       autocomplete="off"
                       class="w-full h-14 pl-12 pr-36 bg-gray-800/50 border border-gray-700 rounded-2xl text-gray-100 placeholder-gray-500 focus:outline-none focus:border-gold focus:ring-2 focus:ring-gold/20 transition-all duration-300">
                <c:if test="${not empty categorieId}">
                    <input type="hidden" name="categorie" value="${categorieId}">
                </c:if>
                <button type="submit" 
                        class="absolute right-2 h-10 px-6 bg-gradient-to-r from-gold to-gold-dark text-gray-900 font-medium rounded-xl hover:shadow-lg hover:shadow-gold/20 transition-all duration-300">
                    Rechercher
                </button>
            </div>
        </form>
    </div>

    <!-- Layout avec sidebar -->
    <div class="flex flex-col lg:flex-row gap-8 animate-fade-up" style="animation-delay: 0.2s">

        <!-- Sidebar filtres -->
        <aside class="lg:w-80 shrink-0" aria-label="Filtres">
            <div class="sticky top-24 bg-gray-800/40 backdrop-blur-xl border border-gray-700 rounded-3xl p-6">
                <h2 class="text-xl font-display font-semibold text-gold mb-6 flex items-center gap-2">
                    <span class="text-2xl">⚡</span> Filtres
                </h2>

                <form action="${pageContext.request.contextPath}/catalogue" method="get" id="filterForm" class="space-y-6">
                    <c:if test="${not empty keyword}">
                        <input type="hidden" name="q" value="<c:out value='${keyword}'/>">
                    </c:if>

                    <!-- Catégorie -->
                    <div>
                        <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-3">Catégorie</h3>
                        <div class="space-y-2">
                            <label class="flex items-center p-2 rounded-xl cursor-pointer transition-all duration-200 ${empty categorieId ? 'bg-gold/10 border border-gold/30' : 'hover:bg-gray-700/50'}">
                                <input type="radio" name="categorie" value=""
                                       ${empty categorieId ? 'checked' : ''}
                                       onchange="document.getElementById('filterForm').submit()"
                                       class="w-4 h-4 text-gold bg-gray-700 border-gray-600 focus:ring-gold focus:ring-2">
                                <span class="ml-3 text-gray-200">Toutes les catégories</span>
                            </label>
                            <c:forEach var="cat" items="${categories}">
                                <label class="flex items-center p-2 rounded-xl cursor-pointer transition-all duration-200 ${categorieId == cat.id ? 'bg-gold/10 border border-gold/30' : 'hover:bg-gray-700/50'}">
                                    <input type="radio" name="categorie" value="${cat.id}"
                                           ${categorieId == cat.id ? 'checked' : ''}
                                           onchange="document.getElementById('filterForm').submit()"
                                           class="w-4 h-4 text-gold bg-gray-700 border-gray-600 focus:ring-gold focus:ring-2">
                                    <span class="ml-3 text-gray-200">${cat.nom}</span>
                                </label>
                            </c:forEach>
                        </div>
                    </div>

                    <!-- Disponibilité -->
                    <div>
                        <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-3">Disponibilité</h3>
                        <label class="flex items-center p-2 rounded-xl cursor-pointer hover:bg-gray-700/50 transition-all duration-200">
                            <input type="checkbox" name="enStock" value="true" 
                                   onchange="document.getElementById('filterForm').submit()"
                                   class="w-4 h-4 text-gold bg-gray-700 border-gray-600 rounded focus:ring-gold focus:ring-2">
                            <span class="ml-3 text-gray-200">En stock uniquement</span>
                        </label>
                    </div>

                    <!-- Effacer les filtres -->
                    <c:if test="${not empty keyword or not empty categorieId}">
                        <a href="${pageContext.request.contextPath}/catalogue"
                           class="block w-full py-2 px-4 mt-6 bg-gray-700/50 hover:bg-gray-700 text-center text-gray-300 hover:text-white rounded-xl transition-all duration-300 border border-gray-600">
                            ✕ Effacer les filtres
                        </a>
                    </c:if>
                </form>

                <!-- Filtres actifs -->
                <c:if test="${not empty keyword or not empty categorieId}">
                    <div class="mt-6 p-4 bg-gold/5 border border-gold/20 rounded-xl">
                        <p class="text-xs font-semibold text-gold uppercase tracking-wider mb-2">Filtres actifs</p>
                        <c:if test="${not empty keyword}">
                            <div class="text-sm text-gray-300">
                                Recherche : "<c:out value='${keyword}'/>"
                            </div>
                        </c:if>
                    </div>
                </c:if>
            </div>
        </aside>

        <!-- Grille produits -->
        <div class="flex-1">

            <c:choose>
                <c:when test="${empty produits}">
                    <!-- État vide -->
                    <div class="text-center py-16 px-4 bg-gray-800/20 rounded-3xl border border-dashed border-gray-700">
                        <div class="text-7xl mb-4 animate-bounce">🔍</div>
                        <h3 class="text-2xl font-display font-semibold text-gray-300 mb-2">Aucun produit trouvé</h3>
                        <p class="text-gray-400 mb-6">Essayez d'autres mots-clés ou supprimez les filtres</p>
                        <a href="${pageContext.request.contextPath}/catalogue"
                           class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-gold to-gold-dark text-gray-900 font-medium rounded-xl hover:shadow-lg hover:shadow-gold/20 transition-all duration-300">
                            Voir tous les produits
                        </a>
                    </div>
                </c:when>
                <c:otherwise>
                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                        <c:forEach var="produit" items="${produits}" varStatus="loop">
                            <article class="group relative bg-gray-800/30 backdrop-blur-sm border border-gray-700 rounded-3xl overflow-hidden hover:border-gold/50 hover:shadow-2xl hover:shadow-gold/5 transition-all duration-500"
                                     style="animation: fadeUp 0.6s ease-out forwards; animation-delay: ${loop.index * 0.06}s; opacity: 0;">
                                
                                <!-- Image -->
                                <a href="${pageContext.request.contextPath}/produit/detail?id=${produit.id}"
                                   class="block aspect-square overflow-hidden bg-gradient-to-br from-gray-800 to-gray-900">
                                    <c:choose>
                                        <c:when test="${not empty produit.imageUrl}">
                                            <img src="${pageContext.request.contextPath}/images/airpodpro2.jpg"
                                                 alt="${produit.nom}"
                                                 loading="lazy"
                                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                                                 class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                                            <div class="w-full h-full flex items-center justify-center text-6xl text-gold/50 hidden" aria-hidden="true">📱</div>
                                        </c:when>
                                        <c:otherwise>
                                            <div class="w-full h-full flex items-center justify-center text-7xl text-gold/30" aria-hidden="true">
                                                <c:choose>
                                                    <c:when test="${fn:contains(produit.categorie.nom,'Smartphone')}">📱</c:when>
                                                    <c:when test="${fn:contains(produit.categorie.nom,'Ordinateur')}">💻</c:when>
                                                    <c:when test="${fn:contains(produit.categorie.nom,'Audio')}">🎧</c:when>
                                                    <c:when test="${fn:contains(produit.categorie.nom,'Tablette')}">📟</c:when>
                                                    <c:otherwise>🔌</c:otherwise>
                                                </c:choose>
                                            </div>
                                        </c:otherwise>
                                    </c:choose>

                                    <!-- Badge catégorie -->
                                    <span class="absolute top-4 left-4 px-3 py-1 bg-gold text-gray-900 text-xs font-bold rounded-full uppercase tracking-wider">
                                        ${produit.categorie.nom}
                                    </span>

                                    <!-- Badge rupture -->
                                    <c:if test="${produit.stock == 0}">
                                        <span class="absolute bottom-4 left-4 px-3 py-1 bg-rose-600 text-white text-xs font-bold rounded-full uppercase tracking-wider">
                                            Rupture
                                        </span>
                                    </c:if>
                                </a>

                                <!-- Contenu -->
                                <div class="p-5">
                                    <div class="text-xs text-gold font-mono mb-1">${produit.marque}</div>
                                    <h3 class="text-lg font-display font-semibold text-white mb-2 line-clamp-1">
                                        <a href="${pageContext.request.contextPath}/produit/detail?id=${produit.id}" 
                                           class="hover:text-gold transition-colors">
                                            ${produit.nom}
                                        </a>
                                    </h3>
                                    <p class="text-sm text-gray-400 mb-4 line-clamp-2">${produit.description}</p>

                                    <!-- Footer -->
                                    <div class="flex items-center justify-between">
                                        <div>
                                            <span class="text-2xl font-bold text-gold">${produit.prix} €</span>
                                            <c:choose>
                                                <c:when test="${produit.stock == 0}">
                                                    <span class="block text-xs text-rose-400 mt-1">Rupture de stock</span>
                                                </c:when>
                                                <c:when test="${produit.stock <= 5}">
                                                    <span class="block text-xs text-orange-400 mt-1">Plus que ${produit.stock}</span>
                                                </c:when>
                                                <c:otherwise>
                                                    <span class="block text-xs text-emerald-400 mt-1">En stock</span>
                                                </c:otherwise>
                                            </c:choose>
                                        </div>

                                        <c:choose>
                                            <c:when test="${not empty sessionScope.client and not sessionScope.client.admin and produit.stock > 0}">
                                                <form action="${pageContext.request.contextPath}/panier/ajouter" method="post">
                                                    <input type="hidden" name="produitId" value="${produit.id}">
                                                    <input type="hidden" name="quantite" value="1">
                                                    <button type="submit" 
                                                            class="w-12 h-12 flex items-center justify-center bg-gold hover:bg-gold-dark text-gray-900 rounded-2xl transition-all duration-300 hover:scale-110"
                                                            aria-label="Ajouter ${produit.nom} au panier">
                                                        <span class="text-2xl">🛒</span>
                                                    </button>
                                                </form>
                                            </c:when>
                                            <c:when test="${produit.stock == 0}">
                                                <button class="px-4 py-2 bg-gray-700 text-gray-400 rounded-xl cursor-not-allowed" disabled>
                                                    Indisponible
                                                </button>
                                            </c:when>
                                            <c:otherwise>
                                                <a href="${pageContext.request.contextPath}/produit/detail?id=${produit.id}"
                                                   class="px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-xl transition-all duration-300">
                                                    Voir
                                                </a>
                                            </c:otherwise>
                                        </c:choose>
                                    </div>
                                </div>
                            </article>
                        </c:forEach>
                    </div>
                </c:otherwise>
            </c:choose>
        </div>
    </div>
</main>

<!-- Footer -->
<footer class="mt-20 border-t border-gray-800" role="contentinfo">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <p class="text-center text-gray-500 text-sm">
            © 2025 TechShop — Tous droits réservés &bull; Projet E-Commerce JEE
        </p>
    </div>
</footer>

<!-- Script pour les animations et interactions -->
<script>
    // Animation au scroll
    document.addEventListener('DOMContentLoaded', function() {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.group').forEach(el => observer.observe(el));
    });
</script>

</body>
</html>