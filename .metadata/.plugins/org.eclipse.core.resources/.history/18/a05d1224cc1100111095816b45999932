<%@ page contentType="text/html;charset=UTF-8" language="java" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%@ taglib prefix="fmt" uri="jakarta.tags.fmt" %>
<%@ taglib prefix="fn" uri="jakarta.tags.functions" %>
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gestion des Commandes — Admin TechShop</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/style.css">
</head>
<body>
<%@ include file="../../common/navbar.jsp" %>

<div class="admin-layout">
  <nav class="admin-sidebar" aria-label="Navigation administration">
    <div style="padding:0.5rem 0.75rem 1rem;"><div style="font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--gold);">⚙️ Administration</div></div>
    <a href="${pageContext.request.contextPath}/admin" class="admin-nav-item"><span>📊</span> Dashboard</a>
    <a href="${pageContext.request.contextPath}/admin/produits" class="admin-nav-item"><span>📱</span> Produits</a>
    <a href="${pageContext.request.contextPath}/admin/categories" class="admin-nav-item"><span>🏷️</span> Catégories</a>
    <a href="${pageContext.request.contextPath}/admin/commandes" class="admin-nav-item active"><span>📦</span> Commandes</a>
  </nav>

  <main class="admin-content">
    <c:if test="${not empty sessionScope.succes}">
      <div class="alert alert-success"><span>✅</span><span>${sessionScope.succes}</span></div>
      <c:remove var="succes" scope="session"/>
    </c:if>
    <c:if test="${not empty sessionScope.erreur}">
      <div class="alert alert-error"><span>⚠️</span><span>${sessionScope.erreur}</span></div>
      <c:remove var="erreur" scope="session"/>
    </c:if>

    <div class="page-header fade-up">
      <div class="page-breadcrumb">
        <a href="${pageContext.request.contextPath}/admin">Admin</a> <span>›</span> <span>Commandes</span>
      </div>
      <h1 class="page-title">Gestion des <span style="color:var(--gold)">commandes</span></h1>
    </div>

    <%-- Filtres statut --%>
    <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1.5rem;" class="fade-up fade-up-1">
      <a href="${pageContext.request.contextPath}/admin/commandes"
         class="btn btn-sm ${empty statutFiltre ? 'btn-secondary' : 'btn-ghost'}">Toutes</a>
      <a href="${pageContext.request.contextPath}/admin/commandes?statut=EN_COURS"
         class="btn btn-sm ${statutFiltre == 'EN_COURS' ? 'btn-secondary' : 'btn-ghost'}">
        🔄 En cours
      </a>
      <a href="${pageContext.request.contextPath}/admin/commandes?statut=VALIDEE"
         class="btn btn-sm ${statutFiltre == 'VALIDEE' ? 'btn-secondary' : 'btn-ghost'}">
        ✅ Validées
      </a>
      <a href="${pageContext.request.contextPath}/admin/commandes?statut=ANNULEE"
         class="btn btn-sm ${statutFiltre == 'ANNULEE' ? 'btn-secondary' : 'btn-ghost'}">
        ✗ Annulées
      </a>
    </div>

    <div class="table-wrapper fade-up fade-up-2">
      <table class="data-table" aria-label="Liste des commandes">
        <thead>
          <tr>
            <th scope="col">N° Commande</th>
            <th scope="col">Client</th>
            <th scope="col">Date</th>
            <th scope="col">Articles</th>
            <th scope="col">Total</th>
            <th scope="col">Statut</th>
            <th scope="col">Actions</th>
          </tr>
        </thead>
        <tbody>
          <c:forEach var="cmd" items="${commandes}">
            <tr>
              <td>
                <span style="font-family:var(--font-mono);color:var(--text-muted);">#${cmd.id}</span>
              </td>
              <td>
                <div class="td-name">${cmd.client.nomComplet}</div>
                <div style="font-size:0.75rem;color:var(--text-muted);">${cmd.client.email}</div>
              </td>
              <td>
                <span style="font-size:0.83rem;">
                  <fmt:formatDate value="${cmd.dateCommande}" pattern="dd/MM/yyyy"/>
                </span>
                <div style="font-size:0.75rem;color:var(--text-muted);">
                  <fmt:formatDate value="${cmd.dateCommande}" pattern="HH:mm"/>
                </div>
              </td>
              <td>
                <span style="color:var(--text-primary);font-weight:600;">${fn:length(cmd.lignes)}</span>
                <span style="color:var(--text-muted);font-size:0.82rem;"> article${fn:length(cmd.lignes) > 1 ? 's' : ''}</span>
              </td>
              <td>
                <span style="font-family:var(--font-mono);color:var(--gold);font-weight:700;">
                  <fmt:formatNumber value="${cmd.total}" pattern="#,##0.00"/> €
                </span>
              </td>
              <td>
                <c:choose>
                  <c:when test="${cmd.statut == 'EN_COURS'}">
                    <span class="badge badge-en-cours">🔄 En cours</span>
                  </c:when>
                  <c:when test="${cmd.statut == 'VALIDEE'}">
                    <span class="badge badge-validee">✅ Validée</span>
                  </c:when>
                  <c:when test="${cmd.statut.name() eq 'ANNULEE'}">
                    <span class="badge badge-annulee">✗ Annulée</span>
                  </c:when>
                </c:choose>
              </td>
              <td>
                <%-- Changement statut — RM-03 : VALIDEE est définitive --%>
                <c:if test="${cmd.statut == 'EN_COURS'}">
                  <div style="display:flex;gap:0.4rem;flex-wrap:wrap;">
                    <form action="${pageContext.request.contextPath}/admin/commandes/statut" method="post"
                          onsubmit="return confirm('Valider définitivement cette commande ? Cette action est IRRÉVERSIBLE.')">
                      <input type="hidden" name="commandeId" value="${cmd.id}">
                      <input type="hidden" name="statut" value="VALIDEE">
                      <button type="submit" class="btn btn-success btn-sm"
                              aria-label="Valider la commande #${cmd.id}">✅ Valider</button>
                    </form>
                    <form action="${pageContext.request.contextPath}/admin/commandes/statut" method="post"
                          onsubmit="return confirm('Annuler cette commande ?')">
                      <input type="hidden" name="commandeId" value="${cmd.id}">
                      <input type="hidden" name="statut" value="ANNULEE">
                      <button type="submit" class="btn btn-danger btn-sm"
                              aria-label="Annuler la commande #${cmd.id}">✗ Annuler</button>
                    </form>
                  </div>
                </c:if>
                <c:if test="${cmd.statut != 'EN_COURS'}">
                  <%-- RM-03 : commande définitive, aucune action possible --%>
                  <span style="font-size:0.75rem;color:var(--text-muted);font-style:italic;">
                    Définitive (RM-03)
                  </span>
                </c:if>
              </td>
            </tr>
          </c:forEach>
          <c:if test="${empty commandes}">
            <tr>
              <td colspan="7" style="text-align:center;padding:3rem;color:var(--text-muted);">
                Aucune commande trouvée
              </td>
            </tr>
          </c:if>
        </tbody>
      </table>
    </div>
  </main>
</div>

<footer class="site-footer"><p>© 2025 TechShop — Administration</p></footer>
</body>
</html>
