<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="ecommercePU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Entités JPA -->
        <class>models.Categorie</class>
        <class>models.Client</class>
        <class>models.Produit</class>
        <class>models.Commande</class>
        <class>models.LigneCommande</class>
        <class>models.PanierItem</class>

        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <!-- Connexion MySQL - root / 1234 -->
            <property name="jakarta.persistence.jdbc.driver"   value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:mysql://localhost:3306/ecommerce_db?useSSL=false&amp;serverTimezone=UTC&amp;allowPublicKeyRetrieval=true"/>
            <property name="jakarta.persistence.jdbc.user"     value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="1234"/>

            <!-- Hibernate -->
            <property name="hibernate.dialect"              value="org.hibernate.dialect.MySQL8Dialect"/>
            <property name="hibernate.hbm2ddl.auto"         value="validate"/>
            <property name="hibernate.show_sql"             value="true"/>
            <property name="hibernate.format_sql"           value="true"/>
            <property name="hibernate.use_sql_comments"     value="true"/>

            <!-- Pool de connexions C3P0 -->
            <property name="hibernate.c3p0.min_size"        value="2"/>
            <property name="hibernate.c3p0.max_size"        value="10"/>
            <property name="hibernate.c3p0.timeout"         value="300"/>
            <property name="hibernate.c3p0.max_statements"  value="50"/>
        </properties>
    </persistence-unit>

</persistence>