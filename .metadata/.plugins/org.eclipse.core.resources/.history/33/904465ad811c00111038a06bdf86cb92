<%@ page contentType="text/html;charset=UTF-8" language="java" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%@ taglib prefix="fmt" uri="jakarta.tags.fmt" %>
<%@ taglib prefix="fn" uri="jakarta.tags.functions" %>
<c:set var="activePage" value="panier" scope="request"/>
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mon Panier — TechShop</title>
  <!-- TailwindCSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Configuration Tailwind personnalisée -->
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            gold: '#D4AF37',
            'gold-dark': '#B8860B',
            'green-ok': '#4cdb8f',
            'text-muted': '#9ca3af',
            'text-secondary': '#d1d5db',
            'border': '#374151',
          },
          fontFamily: {
            display: ['Syne', 'sans-serif'],
            sans: ['DM Sans', 'sans-serif'],
            mono: ['DM Mono', 'monospace'],
          },
          animation: {
            'fade-up': 'fadeUp 0.6s ease-out forwards',
          },
          keyframes: {
            fadeUp: {
              '0%': { opacity: '0', transform: 'translateY(20px)' },
              '100%': { opacity: '1', transform: 'translateY(0)' },
            }
          }
        }
      }
    }
  </script>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400&display=swap" rel="stylesheet">
</head>
<body class="bg-gradient-to-br from-gray-950 via-gray-900 to-gray-950 text-gray-100 min-h-screen font-sans antialiased">
<%@ include file="../common/navbar.jsp" %>

<!-- Main Content -->
<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">

  <!-- Fil d'Ariane -->
  <div class="mb-6 animate-fade-up">
    <div class="flex items-center gap-2 text-sm text-gray-500">
      <a href="${pageContext.request.contextPath}/catalogue" class="hover:text-gold transition-colors">Catalogue</a>
      <span class="text-gray-600">›</span>
      <span class="text-gray-300">Mon panier</span>
    </div>
    <h1 class="text-3xl md:text-4xl font-display font-bold mt-2">
      Mon Panier
      <c:if test="${not empty panierItems}">
        <span class="text-lg text-gray-500 font-normal ml-2">
          (${fn:length(panierItems)} article${fn:length(panierItems) > 1 ? 's' : ''})
        </span>
      </c:if>
    </h1>
  </div>

  <c:if test="${not empty erreur}">
    <div class="mb-6 p-4 bg-rose-900/50 border border-rose-600 rounded-xl flex items-center gap-3 text-rose-200 animate-fade-up" role="alert">
      <span class="text-2xl" aria-hidden="true">⚠️</span>
      <span>${erreur}</span>
    </div>
  </c:if>

  <c:choose>

    <%-- Panier vide --%>
    <c:when test="${empty panierItems}">
      <div class="text-center py-20 px-4 bg-gray-800/20 rounded-3xl border border-dashed border-gray-700 animate-fade-up">
        <div class="text-7xl mb-6" aria-hidden="true">🛒</div>
        <h2 class="text-2xl font-display font-semibold text-gray-300 mb-3">
          Votre panier est vide
        </h2>
        <p class="text-gray-400 mb-8">
          Découvrez notre catalogue de produits électroniques premium
        </p>
        <a href="${pageContext.request.contextPath}/catalogue" 
           class="inline-flex items-center gap-3 px-6 py-3 bg-gradient-to-r from-gold to-gold-dark text-gray-900 font-medium rounded-xl hover:shadow-lg hover:shadow-gold/20 transition-all duration-300">
          <span>🏪</span> Explorer le catalogue
        </a>
      </div>
    </c:when>

    <%-- Panier avec articles --%>
    <c:otherwise>
      <div class="flex flex-col lg:flex-row gap-8 animate-fade-up" style="animation-delay: 0.1s">

        <%-- Liste des articles --%>
        <div class="flex-1 space-y-4" role="list" aria-label="Articles du panier">
          <c:forEach var="item" items="${panierItems}" varStatus="loop">
            <div class="bg-gray-800/30 backdrop-blur-sm border border-gray-700 rounded-2xl p-5 flex flex-col md:flex-row gap-5 transition-all duration-300 hover:border-gold/30"
                 role="listitem"
                 style="animation:fadeUp 0.4s ease ${loop.index * 0.08}s both;">
              
              <!-- Image -->
              <div class="w-full md:w-32 h-32 bg-gray-900/50 rounded-xl flex items-center justify-center overflow-hidden">
                <c:choose>
                  <c:when test="${not empty item.produit.imageUrl}">
                    <img src="${pageContext.request.contextPath}/resources/images/produits/${item.produit.imageUrl}"
                         alt="${item.produit.nom}"
                         class="w-full h-full object-cover"
                         onerror="this.style.display='none'">
                  </c:when>
                  <c:otherwise>
                    <span class="text-4xl text-gray-600" aria-hidden="true">📦</span>
                  </c:otherwise>
                </c:choose>
              </div>

              <!-- Infos -->
              <div class="flex-1">
                <div class="text-xs text-gold font-mono mb-1">${item.produit.marque}</div>
                <div class="text-lg font-display font-semibold mb-2">
                  <a href="${pageContext.request.contextPath}/produit/detail?id=${item.produit.id}" 
                     class="hover:text-gold transition-colors">
                    ${item.produit.nom}
                  </a>
                </div>
                <div class="text-base text-gray-300 mb-3">
                  ${item.produit.prix} € × ${item.quantite} =
                  <strong class="text-gold">
                    <fmt:formatNumber value="${item.sousTotal}" pattern="#,##0.00"/> €
                  </strong>
                </div>
                <c:if test="${item.produit.stock < item.quantite}">
                  <div class="text-sm text-rose-400 flex items-center gap-1" role="alert">
                    ⚠ Stock insuffisant (${item.produit.stock} disponible${item.produit.stock > 1 ? 's' : ''})
                  </div>
                </c:if>
              </div>

              <!-- Actions -->
              <div class="flex flex-row md:flex-col items-center md:items-end justify-between md:justify-start gap-4">
                <form action="${pageContext.request.contextPath}/panier/modifier" method="post"
                      class="flex items-center gap-2"
                      aria-label="Modifier la quantité de ${item.produit.nom}">
                  <input type="hidden" name="itemId" value="${item.id}">
                  <div class="flex items-center bg-gray-900/50 border border-gray-700 rounded-xl overflow-hidden">
                    <button type="button" 
                            class="w-10 h-10 flex items-center justify-center text-gray-400 hover:text-white hover:bg-gray-800 transition-colors"
                            onclick="changeQty(${item.id}, -1)"
                            aria-label="Diminuer la quantité">−</button>
                    <span class="w-12 text-center font-medium" id="qty-${item.id}" aria-live="polite">${item.quantite}</span>
                    <button type="button" 
                            class="w-10 h-10 flex items-center justify-center text-gray-400 hover:text-white hover:bg-gray-800 transition-colors"
                            onclick="changeQty(${item.id}, 1, ${item.produit.stock})"
                            aria-label="Augmenter la quantité">+</button>
                  </div>
                  <input type="hidden" name="quantite" id="qty-input-${item.id}" value="${item.quantite}">
                  <button type="submit" class="px-4 h-10 bg-gray-700 hover:bg-gray-600 text-sm font-medium rounded-xl transition-colors">Maj</button>
                </form>

                <form action="${pageContext.request.contextPath}/panier/supprimer" method="post">
                  <input type="hidden" name="itemId" value="${item.id}">
                  <button type="submit" 
                          class="w-10 h-10 flex items-center justify-center bg-rose-600/20 hover:bg-rose-600/40 text-rose-400 rounded-xl transition-colors"
                          aria-label="Supprimer ${item.produit.nom} du panier"
                          onclick="return confirm('Supprimer cet article ?')">
                    🗑
                  </button>
                </form>
              </div>
            </div>
          </c:forEach>

          <!-- Bouton continuer les achats -->
          <a href="${pageContext.request.contextPath}/catalogue"
             class="inline-flex items-center gap-2 px-4 py-2 text-gray-400 hover:text-gold transition-colors mt-4">
            ← Continuer mes achats
          </a>
        </div>

        <!-- Récapitulatif -->
        <aside class="lg:w-96 shrink-0" aria-label="Récapitulatif de commande">
          <div class="sticky top-24 bg-gray-800/40 backdrop-blur-xl border border-gray-700 rounded-3xl p-6"
               style="animation:fadeUp 0.6s ease 0.2s both;">
            <h2 class="text-lg font-display font-bold mb-6">Récapitulatif</h2>

            <div class="space-y-3 mb-5">
              <c:forEach var="item" items="${panierItems}">
                <div class="flex justify-between text-sm text-gray-400">
                  <span>${item.produit.nom} ×${item.quantite}</span>
                  <span><fmt:formatNumber value="${item.sousTotal}" pattern="#,##0.00"/> €</span>
                </div>
              </c:forEach>
            </div>

            <div class="border-t border-gray-700 pt-4 mb-6 space-y-2">
              <div class="flex justify-between text-sm text-gray-400">
                <span>Sous-total</span>
                <span><fmt:formatNumber value="${total}" pattern="#,##0.00"/> €</span>
              </div>
              <div class="flex justify-between text-sm text-gray-400">
                <span>Livraison</span>
                <span class="text-green-500">Gratuite</span>
              </div>
              <div class="flex justify-between items-baseline pt-4 border-t border-gray-700">
                <span class="font-semibold">Total TTC</span>
                <span class="font-display text-2xl font-extrabold text-gold">
                  <fmt:formatNumber value="${total}" pattern="#,##0.00"/> €
                </span>
              </div>
            </div>

            <a href="${pageContext.request.contextPath}/commande/valider"
               class="w-full h-12 bg-gradient-to-r from-gold to-gold-dark text-gray-900 font-medium rounded-xl hover:shadow-lg hover:shadow-gold/20 transition-all duration-300 flex items-center justify-center gap-2"
               aria-label="Procéder au paiement — Total : ${total} €">
              <span>🔒</span> Passer la commande
            </a>

            <div class="mt-4 text-center text-xs text-gray-500">
              <span>🔒</span> Paiement 100% sécurisé — Données chiffrées
            </div>
          </div>
        </aside>
      </div>
    </c:otherwise>
  </c:choose>
</main>

<!-- Footer -->
<footer class="mt-20 border-t border-gray-800" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <p class="text-center text-gray-500 text-sm">© 2025 TechShop</p>
  </div>
</footer>

<script>
  function changeQty(itemId, delta, max) {
	let curent=parseInt(document.getElementById('qty_'+itemId).textContent);
    let newQty = current + delta;
    if (newQty < 0) newQty = 0;
    if (max && newQty > max) { 
      alert('Stock insuffisant (max : ' + max + ')'); 
      return; 
    }
    document.getElementById('qty-' + itemId).textContent = newQty;
    document.getElementById('qty-input-' + itemId).value = newQty;
  }
</script>
</body>
</html>