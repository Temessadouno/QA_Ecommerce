package controllers.services;


import java.math.BigDecimal;
import java.util.List;
import java.util.Optional;

import dao.panier.*;
import dao.produit.*;
import models.*;

/**
 * Service de gestion du panier.
 * Règle RM-02 : la quantité ne peut pas dépasser le stock.
 */
public class PanierServices {

    private final PanierDAO panierDAO;
    private final ProduitDAO produitDAO;

    public PanierServices() {
        this.panierDAO  = new PanierDAOImplement();
        this.produitDAO = new ProduitDAOImplement();
    }

    public PanierServices(PanierDAO panierDAO, ProduitDAO produitDAO) {
        this.panierDAO  = panierDAO;
        this.produitDAO = produitDAO;
    }

    /**
     * Ajoute un produit au panier. Si déjà présent, incrémente la quantité.
     * RM-02 : vérifie que la quantité totale ne dépasse pas le stock.
     */
    public PanierItem ajouterAuPanier(Client client, Integer produitId, int quantite) {
        if (quantite <= 0) {
            throw new PanierException("La quantité doit être supérieure à 0");
        }

        Optional<Produit> optProduit = produitDAO.findById(produitId);
        if (optProduit.isEmpty()) {
            throw new PanierException("Produit introuvable");
        }
        Produit produit = optProduit.get();

        // RM-02 : vérification du stock
        Optional<PanierItem> existing = panierDAO.findByClientAndProduit(client.getId(), produitId);
        int totalDemande = quantite + existing.map(PanierItem::getQuantite).orElse(0);

        if (!produit.isDisponible(totalDemande)) {
            throw new CommandeService.StockInsuffisantException(
                "Stock insuffisant pour « " + produit.getNom() + " » " +
                "(demandé : " + totalDemande + ", disponible : " + produit.getStock() + ")"
            );
        }

        if (existing.isPresent()) {
            PanierItem item = existing.get();
            item.setQuantite(totalDemande);
            return panierDAO.update(item);
        } else {
            return panierDAO.save(new PanierItem(client, produit, quantite));
        }
    }

    /**
     * Modifie la quantité d'un article du panier.
     * Si quantite = 0, supprime l'article.
     */
    public void modifierQuantite(Integer itemId, int nouvelleQuantite) {
        if (nouvelleQuantite < 0) {
            throw new PanierException("La quantité ne peut pas être négative");
        }
        if (nouvelleQuantite == 0) {
            panierDAO.delete(itemId);
        } else {
            PanierItem item = panierDAO.findByClientAndProduit(0, 0)
                .orElseThrow(() -> new PanierException("Article panier introuvable"));
            item.setQuantite(nouvelleQuantite);
            panierDAO.update(item);
        }
    }

    public void supprimerArticle(Integer itemId) {
        panierDAO.delete(itemId);
    }

    public List<PanierItem> getPanier(Integer clientId) {
        return panierDAO.findByClientId(clientId);
    }

    public BigDecimal calculerTotal(List<PanierItem> items) {
        return items.stream()
            .map(PanierItem::getSousTotal)
            .reduce(BigDecimal.ZERO, BigDecimal::add);
    }
    
    public int getPanierCount(Integer clientID) {
    	if (clientID == null) return 0;
    	return panierDAO.getPanierCount(clientID);
    }

    @SuppressWarnings("serial")
	public static class PanierException extends RuntimeException {
        public PanierException(String message) { super(message); }
    }
   
}