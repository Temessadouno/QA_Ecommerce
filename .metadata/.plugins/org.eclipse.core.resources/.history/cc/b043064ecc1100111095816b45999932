<%@ page contentType="text/html;charset=UTF-8" language="java" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%@ taglib prefix="fmt" uri="jakarta.tags.fmt" %>
<c:set var="activePage" value="panier" scope="request"/>
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mon Panier — TechShop</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/style.css">
</head>
<body>
<%@ include file="navbar.jsp" %>

<div class="page-wrapper">
  <div class="page-header fade-up">
    <div class="page-breadcrumb">
      <a href="${pageContext.request.contextPath}/catalogue">Catalogue</a>
      <span>›</span> <span>Mon panier</span>
    </div>
    <h1 class="page-title">Mon Panier
      <c:if test="${not empty panierItems}">
        <span style="font-size:1rem;color:var(--text-muted);font-weight:400;">
          (${fn:length(panierItems)} article${fn:length(panierItems) > 1 ? 's' : ''})
        </span>
      </c:if>
    </h1>
  </div>

  <c:if test="${not empty erreur}">
    <div class="alert alert-error"><span>⚠️</span><span>${erreur}</span></div>
  </c:if>

  <c:choose>

    <%-- Panier vide --%>
    <c:when test="${empty panierItems}">
      <div style="text-align:center;padding:5rem 2rem;fade-up">
        <div style="font-size:5rem;margin-bottom:1.5rem;" aria-hidden="true">🛒</div>
        <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:600;margin-bottom:0.75rem;">
          Votre panier est vide
        </h2>
        <p style="color:var(--text-secondary);margin-bottom:2rem;">
          Découvrez notre catalogue de produits électroniques premium
        </p>
        <a href="${pageContext.request.contextPath}/catalogue" class="btn btn-primary btn-lg">
          <span>🏪</span> Explorer le catalogue
        </a>
      </div>
    </c:when>

    <%-- Panier avec articles --%>
    <c:otherwise>
      <div class="panier-layout fade-up fade-up-1">

        <%-- Articles --%>
        <div role="list" aria-label="Articles du panier">
          <c:forEach var="item" items="${panierItems}" varStatus="loop">
            <div class="panier-item" role="listitem"
                 style="animation:fadeUp 0.4s ease ${loop.index * 0.08}s both;">
              <%-- Image --%>
              <div class="panier-item-img">
                <c:choose>
                  <c:when test="${not empty item.produit.imageUrl}">
                    <img src="${pageContext.request.contextPath}/resources/images/produits/${item.produit.imageUrl}"
                         alt="${item.produit.nom}"
                         onerror="this.style.display='none'">
                  </c:when>
                  <c:otherwise>
                    <span style="font-size:2.5rem;" aria-hidden="true">📦</span>
                  </c:otherwise>
                </c:choose>
              </div>

              <%-- Infos --%>
              <div>
                <div class="panier-item-brand">${item.produit.marque}</div>
                <div class="panier-item-name">
                  <a href="${pageContext.request.contextPath}/produit/detail?id=${item.produit.id}">
                    ${item.produit.nom}
                  </a>
                </div>
                <div class="panier-item-price">
                  ${item.produit.prix} € × ${item.quantite} =
                  <strong style="color:var(--gold);">
                    <fmt:formatNumber value="${item.sousTotal}" pattern="#,##0.00"/> €
                  </strong>
                </div>
                <%-- Alerte stock insuffisant --%>
                <c:if test="${item.produit.stock < item.quantite}">
                  <div class="form-error" role="alert">
                    ⚠ Stock insuffisant (${item.produit.stock} disponible${item.produit.stock > 1 ? 's' : ''})
                  </div>
                </c:if>
              </div>

              <%-- Actions quantité --%>
              <div style="display:flex;flex-direction:column;align-items:flex-end;gap:0.75rem;">
                <form action="${pageContext.request.contextPath}/panier/modifier" method="post"
                      style="display:flex;align-items:center;gap:0.5rem;"
                      aria-label="Modifier la quantité de ${item.produit.nom}">
                  <input type="hidden" name="itemId" value="${item.id}">
                  <div class="qty-control">
                    <button type="button" class="qty-btn"
                            onclick="changeQty(${item.id}, ${item.quantite}, -1)"
                            aria-label="Diminuer la quantité">−</button>
                    <span class="qty-value" id="qty-${item.id}" aria-live="polite">${item.quantite}</span>
                    <button type="button" class="qty-btn"
                            onclick="changeQty(${item.id}, ${item.quantite}, 1, ${item.produit.stock})"
                            aria-label="Augmenter la quantité">+</button>
                  </div>
                  <input type="hidden" name="quantite" id="qty-input-${item.id}" value="${item.quantite}">
                  <button type="submit" class="btn btn-ghost btn-sm">Maj</button>
                </form>

                <form action="${pageContext.request.contextPath}/panier/supprimer" method="post">
                  <input type="hidden" name="itemId" value="${item.id}">
                  <button type="submit" class="btn btn-danger btn-sm"
                          aria-label="Supprimer ${item.produit.nom} du panier"
                          onclick="return confirm('Supprimer cet article ?')">
                    🗑
                  </button>
                </form>
              </div>
            </div>
          </c:forEach>

          <%-- Bouton continuer les achats --%>
          <a href="${pageContext.request.contextPath}/catalogue"
             class="btn btn-ghost" style="margin-top:0.75rem;">
            ← Continuer mes achats
          </a>
        </div>

        <%-- Récapitulatif --%>
        <aside class="panier-summary-card fade-up fade-up-2" aria-label="Récapitulatif de commande">
          <h2 style="font-family:var(--font-display);font-size:1.1rem;font-weight:700;margin-bottom:1.5rem;">
            Récapitulatif
          </h2>

          <div style="display:flex;flex-direction:column;gap:0.6rem;margin-bottom:1.25rem;">
            <c:forEach var="item" items="${panierItems}">
              <div style="display:flex;justify-content:space-between;font-size:0.83rem;color:var(--text-secondary);">
                <span>${item.produit.nom} ×${item.quantite}</span>
                <span><fmt:formatNumber value="${item.sousTotal}" pattern="#,##0.00"/> €</span>
              </div>
            </c:forEach>
          </div>

          <div style="border-top:1px solid var(--border);padding-top:1rem;margin-bottom:1.5rem;">
            <div style="display:flex;justify-content:space-between;font-size:0.85rem;color:var(--text-secondary);margin-bottom:0.4rem;">
              <span>Sous-total</span>
              <span><fmt:formatNumber value="${total}" pattern="#,##0.00"/> €</span>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:0.85rem;color:var(--text-secondary);margin-bottom:0.75rem;">
              <span>Livraison</span>
              <span style="color:var(--green-ok);">Gratuite</span>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:baseline;padding-top:0.75rem;border-top:1px solid var(--border);">
              <span style="font-weight:600;">Total TTC</span>
              <span style="font-family:var(--font-display);font-size:1.5rem;font-weight:800;color:var(--gold);">
                <fmt:formatNumber value="${total}" pattern="#,##0.00"/> €
              </span>
            </div>
          </div>

          <a href="${pageContext.request.contextPath}/commande/valider"
             class="btn btn-primary btn-full btn-lg"
             style="text-decoration:none;display:flex;justify-content:center;"
             aria-label="Procéder au paiement — Total : ${total} €">
            <span>🔒</span> Passer la commande
          </a>

          <div style="margin-top:1rem;text-align:center;font-size:0.75rem;color:var(--text-muted);">
            <span>🔒</span> Paiement 100% sécurisé — Données chiffrées
          </div>
        </aside>
      </div>
    </c:otherwise>
  </c:choose>
</div>

<footer class="site-footer"><p>© 2025 TechShop</p></footer>

<script>
  function changeQty(itemId, current, delta, max) {
    let newQty = current + delta;
    if (newQty < 0) newQty = 0;
    if (max && newQty > max) { alert('Stock insuffisant (max : ' + max + ')'); return; }
    document.getElementById('qty-' + itemId).textContent = newQty;
    document.getElementById('qty-input-' + itemId).value = newQty;
  }
</script>
</body>
</html>
