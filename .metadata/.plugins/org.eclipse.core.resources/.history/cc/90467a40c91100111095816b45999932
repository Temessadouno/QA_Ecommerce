package controllers;

import models.Client;
import jakarta.servlet.*;
import jakarta.servlet.annotation.WebFilter;
import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpServletResponse;
import jakarta.servlet.http.HttpSession;

import java.io.IOException;

/**
 * Filtre d'authentification.
 * Protège les routes nécessitant une session active (RM-01).
 * Redirige vers /login si la session est absente ou expirée.
 */
@WebFilter(urlPatterns = {"/panier/*", "/commande/*", "/client/*"})
public class AuthFilter implements Filter {

    @Override
    public void doFilter(ServletRequest request, ServletResponse response, FilterChain chain)
            throws IOException, ServletException {

        HttpServletRequest  req  = (HttpServletRequest)  request;
        HttpServletResponse resp = (HttpServletResponse) response;

        HttpSession session = req.getSession(false);
        boolean estConnecte = session != null && session.getAttribute("client") != null;

        if (!estConnecte) {
            // Mémoriser l'URL demandée pour redirection après connexion
            String url = req.getRequestURI();
            if (req.getQueryString() != null) url += "?" + req.getQueryString();
            req.getSession(true).setAttribute("redirectAfterLogin", url);

            resp.sendRedirect(req.getContextPath() + "/login");
        } else {
            chain.doFilter(request, response);
        }
    }
}