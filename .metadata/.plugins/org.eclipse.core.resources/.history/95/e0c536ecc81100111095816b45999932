<%@ page contentType="text/html;charset=UTF-8" language="java" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%@ taglib prefix="fmt" uri="jakarta.tags.fmt" %>
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gestion des Produits — Admin TechShop</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/style.css">
</head>
<body>
<%@ include file="../../common/navbar.jsp" %>

<div class="admin-layout">
  <%-- Sidebar --%>
  <nav class="admin-sidebar" aria-label="Navigation administration">
    <div style="padding:0.5rem 0.75rem 1rem;margin-bottom:0.5rem;">
      <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--gold);">⚙️ Administration</div>
    </div>
    <div class="admin-nav-section">
      <div class="admin-nav-label">Tableau de bord</div>
      <a href="${pageContext.request.contextPath}/admin" class="admin-nav-item">
        <span class="admin-nav-icon">📊</span> Vue d'ensemble
      </a>
    </div>
    <div class="admin-nav-section">
      <div class="admin-nav-label">Catalogue</div>
      <a href="${pageContext.request.contextPath}/admin/produits" class="admin-nav-item active">
        <span class="admin-nav-icon">📱</span> Produits
      </a>
      <a href="${pageContext.request.contextPath}/admin/categories" class="admin-nav-item">
        <span class="admin-nav-icon">🏷️</span> Catégories
      </a>
    </div>
    <div class="admin-nav-section">
      <div class="admin-nav-label">Ventes</div>
      <a href="${pageContext.request.contextPath}/admin/commandes" class="admin-nav-item">
        <span class="admin-nav-icon">📦</span> Commandes
      </a>
    </div>
  </nav>

  <main class="admin-content">
    <c:if test="${not empty sessionScope.succes}">
      <div class="alert alert-success"><span>✅</span><span>${sessionScope.succes}</span></div>
      <c:remove var="succes" scope="session"/>
    </c:if>
    <c:if test="${not empty sessionScope.erreur}">
      <div class="alert alert-error"><span>⚠️</span><span>${sessionScope.erreur}</span></div>
      <c:remove var="erreur" scope="session"/>
    </c:if>

    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;margin-bottom:2rem;" class="fade-up">
      <div>
        <div class="page-breadcrumb">
          <a href="${pageContext.request.contextPath}/admin">Admin</a>
          <span>›</span> <span>Produits</span>
        </div>
        <h1 class="page-title">Gestion des <span style="color:var(--gold)">produits</span></h1>
        <p class="page-subtitle">${fn:length(produits)} produit${fn:length(produits) > 1 ? 's' : ''} actif${fn:length(produits) > 1 ? 's' : ''}</p>
      </div>
      <a href="${pageContext.request.contextPath}/admin/produits/nouveau"
         class="btn btn-primary">
        <span>➕</span> Nouveau produit
      </a>
    </div>

    <%-- Filtre rapide par catégorie --%>
    <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1.5rem;" class="fade-up fade-up-1">
      <a href="${pageContext.request.contextPath}/admin/produits"
         class="btn btn-sm ${empty param.categorie ? 'btn-secondary' : 'btn-ghost'}">Tous</a>
      <c:forEach var="cat" items="${categories}">
        <a href="${pageContext.request.contextPath}/admin/produits?categorie=${cat.id}"
           class="btn btn-sm ${param.categorie == cat.id ? 'btn-secondary' : 'btn-ghost'}">
          ${cat.nom}
        </a>
      </c:forEach>
    </div>

    <div class="table-wrapper fade-up fade-up-2">
      <table class="data-table" aria-label="Liste des produits">
        <thead>
          <tr>
            <th scope="col">Produit</th>
            <th scope="col">Catégorie</th>
            <th scope="col">Prix</th>
            <th scope="col">Stock</th>
            <th scope="col">Statut</th>
            <th scope="col">Actions</th>
          </tr>
        </thead>
        <tbody>
          <c:forEach var="p" items="${produits}">
            <tr>
              <td>
                <div style="display:flex;align-items:center;gap:0.9rem;">
                  <div style="width:40px;height:40px;background:var(--bg-elevated);border-radius:var(--radius-sm);
                               display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;">
                    <c:choose>
                      <c:when test="${not empty p.imageUrl}">
                        <img src="${pageContext.request.contextPath}/resources/images/produits/${p.imageUrl}"
                             alt="" style="width:36px;height:36px;object-fit:contain;"
                             onerror="this.style.display='none'">
                      </c:when>
                      <c:otherwise>📦</c:otherwise>
                    </c:choose>
                  </div>
                  <div>
                    <div class="td-name">${p.nom}</div>
                    <div style="font-size:0.75rem;color:var(--text-muted);">${p.marque}</div>
                  </div>
                </div>
              </td>
              <td>
                <span class="badge badge-en-cours" style="font-size:0.68rem;">${p.categorie.nom}</span>
              </td>
              <td>
                <span style="font-family:var(--font-mono);color:var(--gold);font-weight:600;">
                  <fmt:formatNumber value="${p.prix}" pattern="#,##0.00"/> €
                </span>
              </td>
              <td>
                <div style="display:flex;align-items:center;gap:0.5rem;">
                  <c:choose>
                    <c:when test="${p.stock == 0}">
                      <span class="badge badge-annulee">Rupture</span>
                    </c:when>
                    <c:when test="${p.stock <= 5}">
                      <span style="color:var(--gold);font-weight:600;">${p.stock}</span>
                      <span class="badge badge-en-cours">Faible</span>
                    </c:when>
                    <c:otherwise>
                      <span style="color:var(--text-primary);font-weight:600;">${p.stock}</span>
                    </c:otherwise>
                  </c:choose>
                </div>
              </td>
              <td>
                <c:choose>
                  <c:when test="${p.stock > 0}">
                    <span class="badge badge-validee">Actif</span>
                  </c:when>
                  <c:otherwise>
                    <span class="badge badge-annulee">Indisponible</span>
                  </c:otherwise>
                </c:choose>
              </td>
              <td>
                <div style="display:flex;gap:0.5rem;">
                  <a href="${pageContext.request.contextPath}/admin/produits/modifier?id=${p.id}"
                     class="btn btn-ghost btn-sm" aria-label="Modifier ${p.nom}">✏️</a>
                  <form action="${pageContext.request.contextPath}/admin/produits/supprimer"
                        method="post" style="display:inline;"
                        onsubmit="return confirm('Supprimer « ${p.nom} » ? Cette action est irréversible.')">
                    <input type="hidden" name="id" value="${p.id}">
                    <button type="submit" class="btn btn-danger btn-sm"
                            aria-label="Supprimer ${p.nom}">🗑️</button>
                  </form>
                </div>
              </td>
            </tr>
          </c:forEach>
          <c:if test="${empty produits}">
            <tr>
              <td colspan="6" style="text-align:center;padding:3rem;color:var(--text-muted);">
                Aucun produit trouvé
              </td>
            </tr>
          </c:if>
        </tbody>
      </table>
    </div>
  </main>
</div>

<footer class="site-footer"><p>© 2025 TechShop — Administration</p></footer>
</body>
</html>
