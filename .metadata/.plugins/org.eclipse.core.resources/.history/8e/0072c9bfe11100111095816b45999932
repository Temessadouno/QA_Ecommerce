<%@ page contentType="text/html;charset=UTF-8" language="java" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%@ taglib prefix="fmt" uri="jakarta.tags.fmt" %>
<%@ taglib prefix="fn" uri="jakarta.tags.functions" %>
<c:set var="activePage" value="commandes" scope="request"/>
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mes Commandes — TechShop</title>
    <!-- TailwindCSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/style.css">
</head>
<body class="bg-gradient-to-br from-gray-950 via-gray-900 to-gray-950 text-gray-100 min-h-screen font-sans antialiased">
<%@ include file="../common/navbar.jsp" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
  <div class="mb-10 animate-fade-up">
    <h1 class="text-3xl md:text-4xl font-display font-bold tracking-tight mb-2">Mes <span class="text-gold">commandes</span></h1>
    <p class="text-gray-400">Historique et suivi de vos commandes</p>
  </div>

  <c:choose>
    <c:when test="${empty commandes}">
      <div class="text-center py-20 px-4 bg-gray-800/20 rounded-3xl border border-dashed border-gray-700 animate-fade-up">
        <div class="text-7xl mb-6" aria-hidden="true">📦</div>
        <h2 class="text-2xl font-display font-semibold text-gray-300 mb-3">Aucune commande pour le moment</h2>
        <p class="text-gray-400 mb-8">Commencez par explorer notre catalogue</p>
        <a href="${pageContext.request.contextPath}/catalogue" class="inline-flex items-center gap-3 px-6 py-3 bg-gradient-to-r from-gold to-gold-dark text-gray-900 font-medium rounded-xl hover:shadow-lg hover:shadow-gold/20 transition-all duration-300">
          🏪 Découvrir le catalogue
        </a>
      </div>
    </c:when>
    <c:otherwise>
      <div class="space-y-4 animate-fade-up" style="animation-delay: 0.1s">
        <c:forEach var="commande" items="${commandes}" varStatus="loop">
          <div class="bg-gray-800/30 backdrop-blur-sm border border-gray-700 rounded-2xl p-6 transition-all duration-300 hover:border-gold/30" style="animation:fadeUp 0.4s ease ${loop.index * 0.08}s both;">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-4">
              <div>
                <div class="flex items-center gap-3 mb-1">
                  <span class="font-mono text-sm text-gray-500">#${commande.id}</span>
                  <c:choose>
                    <c:when test="${commande.statut == 'EN_COURS'}">
                      <span class="px-2 py-1 bg-gold/10 text-gold text-xs font-bold rounded-full border border-gold/20 flex items-center gap-1">🔄 En cours</span>
                    </c:when>
                    <c:when test="${commande.statut == 'VALIDEE'}">
                      <span class="px-2 py-1 bg-emerald-500/10 text-emerald-500 text-xs font-bold rounded-full border border-emerald-500/20 flex items-center gap-1">✅ Validée</span>
                    </c:when>
                    <c:when test="${commande.statut == 'ANNULEE'}">
                      <span class="px-2 py-1 bg-rose-500/10 text-rose-500 text-xs font-bold rounded-full border border-rose-500/20 flex items-center gap-1">✗ Annulée</span>
                    </c:when>
                  </c:choose>
                </div>
                <div class="text-xs text-gray-500">
                  <fmt:formatDate value="${commande.dateCommande}" pattern="dd/MM/yyyy à HH:mm"/>
                </div>
              </div>
              <div class="text-right">
                <div class="font-display text-2xl font-bold text-gold">
                  <fmt:formatNumber value="${commande.total}" pattern="#,##0.00"/> €
                </div>
                <div class="text-xs text-gray-500">
                  ${fn:length(commande.lignes)} article${fn:length(commande.lignes) > 1 ? 's' : ''}
                </div>
              </div>
            </div>

            <%-- Lignes de commande --%>
            <div class="border-t border-gray-700 pt-4">
              <c:forEach var="ligne" items="${commande.lignes}">
                <div class="flex justify-between items-center py-2 text-sm">
                  <div class="flex items-center gap-3">
                    <span class="text-gray-500 font-mono bg-gray-900/50 px-2 py-0.5 rounded">×${ligne.quantite}</span>
                    <span class="text-gray-300">${ligne.produit.nom}</span>
                  </div>
                  <span class="text-gray-400">
                    <fmt:formatNumber value="${ligne.sousTotal}" pattern="#,##0.00"/> €
                  </span>
                </div>
              </c:forEach>
            </div>

            <div class="mt-4 pt-4 border-t border-gray-700 text-xs text-gray-500 flex items-center gap-2">
              📍 Livraison : ${commande.adresseLivraison}
            </div>
          </div>
        </c:forEach>
      </div>
    </c:otherwise>
  </c:choose>
</div>

<footer class="border-t border-gray-800 mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <p class="text-center text-gray-500 text-sm">© 2025 TechShop</p>
  </div>
</footer>
</body>
</html>